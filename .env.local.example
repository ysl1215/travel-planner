# ─── Required: AI features (destination suggestions, itinerary, chat) ─────────
# Get a free key at https://openrouter.ai/keys (takes < 1 minute, no credit card)
OPENROUTER_API_KEY=your_openrouter_api_key_here

# ─── Optional: model override ──────────────────────────────────────────────────
# Any model slug from https://openrouter.ai/models  (leave blank = free Llama 3.3 70B)
# Examples:
#   meta-llama/llama-3.3-70b-instruct:free   ← default (free tier)
#   anthropic/claude-3.5-sonnet              ← paid
#   openai/gpt-4o                            ← paid
#   google/gemini-2.0-flash-exp:free         ← free
# OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free
